" .ideavimrc — IdeaVim entry point. Reuses the portable shared base.
"
" IdeaVim doesn't implement plugin autoload, augroup, or some less-common
" options, but `set`, `map`, and `let` work. Anything from common.vim that
" IdeaVim can't honor will fail silently with `silent!`.

let mapleader=","

silent! source ~/dotfiles/vim/shared/common.vim
