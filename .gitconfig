[core]
	editor = nvim
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = main
[safe]
	directory = /workspace
[merge]
	conflictstyle = diff3
[diff]
	algorithm = histogram
# Per-machine identity (user.name / user.email) and any other per-host overrides.
# The husk is created empty by setup.sh; populate it on each machine.
[include]
	path = ~/.local/dotfiles/.gitconfig
